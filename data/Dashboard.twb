      <aliases enabled='yes' />
      <column caption='Churn Percentage' datatype='real' name='[Calculation_6406852653277191]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#10;    IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END&#10;) / COUNT([customerID])' />
      </column>
      <column caption='Customer Count' datatype='integer' name='[Calculation_6406852661682184]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customerID])' />
      </column>
      <column caption='Tenure Field' datatype='string' name='[Calculation_6406852663406601]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure] &lt;= 12 THEN &quot;0-1 Year&quot;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;1-2 Years&quot;&#10;ELSE &quot;2+ Years&quot;&#10;END' />
      </column>
